  "strings" : {
    "%@ outdated" : {
      "comment" : "A label at the top of the view showing how many packages in the system are outdated. The argument is the count of outdated packages.",
      "isCommentAutoGenerated" : true
    },
    "%@ → %@" : {
      "comment" : "A label showing the current and new version of a package, indicating an update is available. The first argument is the current version of the package. The second argument is the new version of the package.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ → %2$@"
          }
        }
      }
    },
    "+ %@ more..." : {
      "comment" : "A label at the bottom of the outdated packages section that indicates there are more packages to show. The number inside the parentheses is the count of additional outdated packages.",
